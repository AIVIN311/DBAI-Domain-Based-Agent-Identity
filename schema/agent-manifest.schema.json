{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dbai.example/schema/agent-manifest.schema.json",
  "title": "DBAI Agent Manifest v0.1 (MVP)",
  "type": "object",
  "additionalProperties": true,
  "required": ["id", "anchor", "controllers", "endpoints", "keys", "proof"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "anchor": { "type": "string", "minLength": 1 },
    "controllers": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "endpoints": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "keys": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "type"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 },
          "publicKeyJwk": { "type": "object", "additionalProperties": true },
          "publicKeyMultibase": { "type": "string" }
        }
      }
    },
    "assertions": { "type": "object", "additionalProperties": true },
    "revocations": { "type": "object", "additionalProperties": true },
    "extensions": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "schema": { "type": "string" },
          "schema_hash": { "type": "string" }
        }
      }
    },
    "proof": {
      "type": "object",
      "additionalProperties": true,
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "created": { "type": "string" },
        "verificationMethod": { "type": "string" },
        "jws": { "type": "string" },
        "cose": { "type": "string" }
      }
    }
  }
}